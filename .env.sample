# Password for SSH / sudo access
USER_PASSWORD=changeme

# Timezone (default: America/Los_Angeles)
TZ=America/Los_Angeles

# OpenAI API key for Codex
OPENAI_API_KEY=sk-your-key-here

# OpenAI OAuth token for Codex login (e.g. from `codex login`)
OPENAI_OAUTH_TOKEN=

# Git identity
GIT_USER=codex
GIT_EMAIL=codex@

# Port configuration
HTTP_PORT=80
HTTPS_PORT=443
SSH_PORT=2222
